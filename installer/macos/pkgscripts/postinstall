#!/bin/bash
set -euo pipefail

APP_SUPPORT_DIR="/Library/Application Support/CSUStudentWiFi"
APP_BUNDLE="/Applications/CSUStudentWiFi.app"
APP_CONTENTS="$APP_BUNDLE/Contents"
APP_EXECUTABLE="$APP_CONTENTS/MacOS/CSUStudentWiFi"
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"

mkdir -p "$APP_CONTENTS/MacOS" "$APP_CONTENTS/Resources"
ln -sfn "$APP_SUPPORT_DIR/bin/csu-auto-relogin-setup" "$APP_EXECUTABLE"

cat >"$APP_CONTENTS/Info.plist" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>zh_CN</string>
    <key>CFBundleDisplayName</key>
    <string>CSUStudentWiFi</string>
    <key>CFBundleExecutable</key>
    <string>CSUStudentWiFi</string>
    <key>CFBundleIdentifier</key>
    <string>cn.csu.autorelogin.desktop</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>CSUStudentWiFi</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.4.4</string>
    <key>CFBundleVersion</key>
    <string>1.4.4</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
EOF

chmod 755 "$APP_EXECUTABLE"
chmod 644 "$APP_CONTENTS/Info.plist"
chown -R root:wheel "$APP_BUNDLE"
touch "$APP_BUNDLE"
if [[ -x "$LSREGISTER" ]]; then
  "$LSREGISTER" -f "$APP_BUNDLE" >/dev/null 2>&1 || true
fi

"/Library/Application Support/CSUStudentWiFi/setup_launch_agent.sh" --load-if-ready || true
